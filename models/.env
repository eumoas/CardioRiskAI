# ─── Banco de dados ───────────────────────────────────────────
DATABASE_URL=postgresql+psycopg2://easespot:easespot@localhost:5432/easespot
POSTGRES_DB=easespot
POSTGRES_USER=easespot
POSTGRES_PASSWORD=easespot

# ─── Câmera ───────────────────────────────────────────────────
CAMERA_INDEX=0

# ─── Detecção ─────────────────────────────────────────────────
CONFIDENCE_THRESHOLD=0.15
REVIEW_THRESHOLD=0.15
DETECTION_CONFIRM_SECONDS=0.0
STREAM_SAVE_INTERVAL=5

# ─── Telegram ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=SEU_TOKEN_AQUI
TELEGRAM_CHAT_ID=SEU_CHAT_ID_AQUI

# ─── E-mail (Gmail com senha de app) ──────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu@gmail.com
SMTP_PASSWORD=sua_senha_de_app

# ─── Destinatários das notificações ───────────────────────────
EMAIL_DESTINO=gestor@empresa.com
EMAIL_GESTOR=gestor@empresa.com

# ─── Servidor da API ──────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ─── LLM local (Ollama — relatório semanal) ───────────────────
LLM_URL=http://localhost:11434/api/generate
LLM_MODEL=tinyllama

# ─── n8n ──────────────────────────────────────────────────────
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=troque_esta_senha
N8N_RUNNERS_ENABLED=true
N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS=true
N8N_WEBHOOK_URL=http://localhost:5678/webhook/easespot-qualidadetextil
EASESPOT_URL=http://host.docker.internal:8000
